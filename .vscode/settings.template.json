{
    "gopls": {
        "ui.semanticTokens": true
    },
    "[go]": {
        "editor.defaultFormatter": "golang.go",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "oxc.typeAware": true,
    "oxc.path.oxfmt": "<PROJECT_ROOT>/frontend/node_modules/oxfmt/bin/oxfmt",
    "oxc.path.oxlint": "<PROJECT_ROOT>/frontend/node_modules/oxlint/bin/oxlint",
    "oxc.path.tsgolint": "<PROJECT_ROOT>/frontend/node_modules/oxlint-tsgolint/bin/tsgolint.js",
    "oxc.configPath": "<PROJECT_ROOT>/frontend/.oxlintrc.json",
    "oxc.fmt.configPath": "<PROJECT_ROOT>/frontend/.oxfmtrc.json",
    "[javascriptreact][typescriptreact][javascript][typescript]": {
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.oxc": "explicit",
            "source.removeUnusedImports": "explicit"
        }
    }
}
